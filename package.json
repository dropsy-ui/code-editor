{
  "name": "@dropsy-ui/code-editor",
  "private": false,
  "version": "1.1.0",
  "type": "module",
  "description": "A React-based embeddable code editor with live HTML/CSS/JS preview",
  "main": "dist/code-editor.umd.js",
  "module": "dist/code-editor.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dropsy-ui/code-editor.git"
  },
  "keywords": [
    "code-editor",
    "monaco-editor",
    "embeddable",
    "live-preview"
  ],
  "author": "Andrew St. Jean",
  "license": "MIT",
  "homepage": "https://github.com/dropsy-ui/code-editor#readme",
  "bugs": {
    "url": "https://github.com/dropsy-ui/code-editor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/standalone": "^7.29.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__standalone": "^7.1.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "process": "^0.11.10",
    "sass-embedded": "^1.99.0",
    "semantic-release": "^25.0.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-css-injected-by-js": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
